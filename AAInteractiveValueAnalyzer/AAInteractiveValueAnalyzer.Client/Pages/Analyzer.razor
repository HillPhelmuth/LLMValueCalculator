                                        }
                                        @if (IsColumnVisible(VisibleRecommendationColumns, "single"))
                                        {
                                            <td class="num">@Percent(item.result.SingleAttemptSuccessRate)</td>
                                        }
                                        @if (IsColumnVisible(VisibleRecommendationColumns, "critical"))
                                        {
                                            <td class="num">@Percent(item.result.CriticalFailureRate, 2)</td>
                                        }
                                        @if (IsColumnVisible(VisibleRecommendationColumns, "attempts"))
                                        {
                                            <td class="num">@Number(item.result.ExpectedAttempts, "0.00")</td>
                                        }
                                        @if (IsColumnVisible(VisibleRecommendationColumns, "direct"))
                                        {
                                            <td class="num">@Currency(item.result.ExpectedTotalDirectCostUsd)</td>
                                        }
                                        @if (IsColumnVisible(VisibleRecommendationColumns, "latency"))
                                        {
                                            <td class="num">@LatencySeconds(item.result)</td>
                                        }
                                        @if (IsColumnVisible(VisibleRecommendationColumns, "costsuccess"))
