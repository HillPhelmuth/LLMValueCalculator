                                            </td>
                                        }
                                        @if (IsColumnVisible(VisibleComparisonColumns, "aacost"))
                                        {
                                            <td class="num">@BatchCurrency(item.Model.CostPerAaTaskUsd)</td>
                                        }
                                        @if (IsColumnVisible(VisibleComparisonColumns, "success"))
                                        {
                                            <td class="num">@Percent(item.EffectiveSuccessRate)</td>
                                        }
                                        @if (IsColumnVisible(VisibleComparisonColumns, "single"))
                                        {
                                            <td class="num">@Percent(item.SingleAttemptSuccessRate)</td>
                                        }
                                        @if (IsColumnVisible(VisibleComparisonColumns, "critical"))
                                        {
                                            <td class="num">@Percent(item.CriticalFailureRate, 2)</td>
                                        }
                                        @if (IsColumnVisible(VisibleComparisonColumns, "attempts"))
                                        {
                                            <td class="num">@Number(item.ExpectedAttempts, "0.00")</td>
                                        }
                                        @if (IsColumnVisible(VisibleComparisonColumns, "modelcost"))
                                        {
                                            <td class="num">@Currency(item.ExpectedModelCostUsd)</td>
                                        }
                                        @if (IsColumnVisible(VisibleComparisonColumns, "review"))
                                        {
                                            <td class="num">@Currency(item.ExpectedReviewCostUsd)</td>
                                        }
                                        @if (IsColumnVisible(VisibleComparisonColumns, "retry"))
                                        {
                                            <td class="num">@Currency(item.ExpectedRetryOverheadUsd)</td>
                                        }
                                        @if (IsColumnVisible(VisibleComparisonColumns, "latency"))
                                        {
                                            <td class="num">@LatencySeconds(item)</td>
                                        }
                                        @if (IsColumnVisible(VisibleComparisonColumns, "latcost"))
                                        {
                                            <td class="num">@LatencyCost(item)</td>
                                        }
                                        @if (IsColumnVisible(VisibleComparisonColumns, "critfail"))
                                        {
                                            <td class="num">@(item.Model.HasCostData ? Currency(item.ExpectedCriticalFailureCostUsd) : "n/a")</td>
                                        }
                                        @if (IsColumnVisible(VisibleComparisonColumns, "benignfail"))
                                        {
                                            <td class="num">@(item.Model.HasCostData ? Currency(item.ExpectedBenignFailureCostUsd) : "n/a")</td>
                                        }
                                        @if (IsColumnVisible(VisibleComparisonColumns, "direct"))
                                        {
                                            <td class="num">@Currency(item.ExpectedTotalDirectCostUsd)</td>
                                        }
                                        @if (IsColumnVisible(VisibleComparisonColumns, "costsuccess"))
                                        {
                                            <td class="num">@Currency(item.CostPerSuccessfulTaskUsd)</td>
                                        }
                                        @if (IsColumnVisible(VisibleComparisonColumns, "successdollar"))
                                        {
                                            <td class="num">@Number(item.SuccessPerDollar, "0.00")</td>
                                        }
                                        @if (IsColumnVisible(VisibleComparisonColumns, "ev"))
                                        {
                                            <td class="num @(item.ExpectedValuePerTaskUsd >= 0 ? "positive" : "negative")">@Currency(item.ExpectedValuePerTaskUsd)</td>
                                        }
                                        @if (IsColumnVisible(VisibleComparisonColumns, "monthly"))
                                        {
                                            <td class="num @(item.MonthlyExpectedValueUsd >= 0 ? "positive" : "negative")">@Currency(item.MonthlyExpectedValueUsd)</td>
                                        }
                                        @if (IsColumnVisible(VisibleComparisonColumns, "status"))
                                        {
                                            <td>
                                                @if (item.IsEligible)
                                                {
                                                    <span class="status-pill ok compact">Eligible</span>
                                                }
                                                else
                                                {
                                                    <span class="status-pill warn compact">Excluded</span>
                                                }
                                            </td>
                                        }
                                        <td class="num action-cell">
                                            <button type="button"
                                                    class="icon-button"
                                                    title="Additional data"
                                                    aria-label="Show additional data for @item.Model.DisplayName"
                                                    @onclick="() => ShowComparisonData(item)">
                                                i
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>

            <section class="dense-footnote">
                <p>
                    Artificial Analysis intelligence and cost values are treated as priors. Production decisions should replace the estimated success curve with measured eval results and real token, retry, tool, latency, review, and critical/benign failure costs.
                </p>
            </section>
        </div>
    </section>
</main>